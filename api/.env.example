# Copy to .env and fill in values (never commit .env)

DATABASE_URL=

# Server (optional)
# PORT=5000

# Resend — contact form POST /api/contact
RESEND_API_KEY=
# Verified domain sender recommended in production, e.g. Portfolio <hello@yourdomain.com>
RESEND_FROM=Portfolio <onboarding@resend.dev>
# Where contact notifications are delivered
EMAIL_TO=

# Optional — POST /api/collaborate via Gmail / Nodemailer
# EMAIL_USER=
# EMAIL_PASS=
